{
  "buildCommand": "npm run build",
  "env": {
    "PRISMA_SKIP_ENGINE_CHECK": "true",
    "NEXTAUTH_URL": "https://$NEXT_PUBLIC_VERCEL_URL",
    "NEXTAUTH_SECRET": "$NEXTAUTH_SECRET"
  },
  "crons": [
    {
      "path": "/api/cron/commits/sync",
      "schedule": "0 0 * * *"
    }
  ],
  "github": {
    "silent": true
  }
}
